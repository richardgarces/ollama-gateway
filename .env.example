# Ollama SaaS Gateway - Variables de entorno
# Copiar a .env y ajustar valores

# Puerto del servidor
PORT=8081

# URL de Ollama (dentro de Docker: http://ollama:11434, local: http://localhost:11434)
OLLAMA_URL=http://ollama:11434

# URL de Qdrant (dentro de Docker: http://qdrant:6333, local: http://localhost:6333)
QDRANT_URL=http://qdrant:6333

# Secreto JWT (mínimo 32 caracteres, puede ser hex)
JWT_SECRET=cambia-esto-por-un-secreto-seguro-de-al-menos-32-chars

# Directorio raíz permitido para lectura de archivos
REPO_ROOT=.

# Máximo de requests por minuto por IP (0 desactiva el límite)
RATE_LIMIT_RPM=60

# Password de MongoDB
MONGO_PASSWORD=changeme
