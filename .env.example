# Ollama SaaS Gateway - variables de entorno
# Copiar a .env y ajustar valores segun topologia.

# -----------------------------
# Core
# -----------------------------
PORT=8081
JWT_SECRET=change-this-with-openssl-rand-hex-32

# Rutas de repositorio
REPO_ROOT=.
# REPO_ROOTS=.,../otro-repo

# Servicios
# Para API en docker-compose principal + Ollama separado en host:
OLLAMA_URL=http://host.docker.internal:11434
QDRANT_URL=http://qdrant:6333
MONGO_URI=mongodb://admin:changeme@mongo:27017

# -----------------------------
# Logging
# -----------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# -----------------------------
# Rate limiting
# -----------------------------
RATE_LIMIT_RPM=60
RATE_LIMIT_USER_RPM=60
# RATE_LIMIT_ENDPOINTS={"POST /openai/v1/chat/completions":30,"POST /api/generate":20}

# -----------------------------
# HTTP resiliencia
# -----------------------------
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3

# -----------------------------
# Health checks (readiness)
# -----------------------------
HEALTH_CHECK_TIMEOUT_MS=2000
# Checks adicionales opcionales en JSON. Tipos soportados: http, tcp.
# HEALTH_EXTRA_CHECKS_JSON=[{"name":"minio","type":"http","target":"http://minio:9000","path":"/minio/health/live","required":false}]

# Preset Docker Compose (todos los servicios en red interna):
# HEALTH_EXTRA_CHECKS_JSON=[]
# (ollama, qdrant, mongo y redis se detectan automaticamente desde OLLAMA_URL, QDRANT_URL, MONGO_URI y REDIS_URL)

# Preset local (desarrollo sin Docker; todo en localhost):
# OLLAMA_URL=http://localhost:11434
# QDRANT_URL=http://localhost:6333
# MONGO_URI=mongodb://localhost:27017
# REDIS_URL=redis://localhost:6379/0

# Ejemplo con backends extras (Minio + Elasticsearch):
# HEALTH_EXTRA_CHECKS_JSON=[{"name":"minio","type":"http","target":"http://minio:9000","path":"/minio/health/live","required":false},{"name":"elasticsearch","type":"http","target":"http://es:9200","path":"/_cluster/health","required":false,"timeout_ms":3000}]

# -----------------------------
# Caches
# -----------------------------
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
EMBEDDING_CACHE_TTL_SECONDS=3600
EMBEDDING_CACHE_MAX_ENTRIES=1000
RAG_CACHE_TTL_SECONDS=1800
RAG_CACHE_MAX_ENTRIES=500

# -----------------------------
# Vector/indexer
# -----------------------------
VECTOR_STORE_PATH=.vector_store.json
VECTOR_STORE_PREFER_LOCAL=false
INDEXER_STATE_PATH=.indexer_state.json

# -----------------------------
# Agentes e integraciones opcionales
# -----------------------------
AGENT_TOOLS_DIR=./agent-tools
REMOTE_API_URL=
REMOTE_API_KEY=

# -----------------------------
# Solo para compose local de mongo
# -----------------------------
MONGO_PASSWORD=changeme
