{
  "openapi": "3.0.3",
  "info": {
    "title": "Ollama Gateway API",
    "version": "1.0.0",
    "description": "API externa del gateway con endpoints versionados y jobs asíncronos."
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "paths": {
    "/api/v1/generate": {
      "post": {
        "summary": "Generar respuesta (v1)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "prompt": { "type": "string" },
                  "stream": { "type": "boolean" }
                },
                "required": ["prompt"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OK" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/v1/search": {
      "post": {
        "summary": "Búsqueda semántica (v1)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": { "type": "string" },
                  "top": { "type": "integer" }
                },
                "required": ["query"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/api/jobs": {
      "post": {
        "summary": "Crear job asíncrono",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "type": { "type": "string" },
                  "params": { "type": "object" }
                },
                "required": ["type"]
              }
            }
          }
        },
        "responses": {
          "202": { "description": "Accepted" },
          "400": { "description": "Bad request" }
        }
      }
    },
    "/api/jobs/{id}": {
      "get": {
        "summary": "Consultar estado de job",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "OK" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/api/spec": {
      "get": {
        "summary": "Obtener especificación OpenAPI",
        "responses": {
          "200": { "description": "OK" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
