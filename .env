# Ollama SaaS Gateway - variables de entorno (local dev)
# Generado para desarrollo local — todos los servicios en localhost

# -----------------------------
# Core
# -----------------------------
PORT=8081
JWT_SECRET=de454c617e0c5420918bc01bf61239c50dd52b03a57b8dc33913e33221f18bd3

# Rutas de repositorio
REPO_ROOT=.

# Servicios (preset local — todo en localhost)
OLLAMA_URL=http://localhost:11434
QDRANT_URL=http://localhost:6333
MONGO_URI=mongodb://localhost:27017

# Modelos
CHAT_MODEL=phi3:latest
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_KEEP_ALIVE=5m

# -----------------------------
# Logging
# -----------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# -----------------------------
# Rate limiting
# -----------------------------
RATE_LIMIT_RPM=300
RATE_LIMIT_USER_RPM=300

# -----------------------------
# HTTP resiliencia
# -----------------------------
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3

# -----------------------------
# Health checks (readiness)
# -----------------------------
HEALTH_CHECK_TIMEOUT_MS=2000

# -----------------------------
# Caches
# -----------------------------
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
EMBEDDING_CACHE_TTL_SECONDS=3600
EMBEDDING_CACHE_MAX_ENTRIES=1000
RAG_CACHE_TTL_SECONDS=1800
RAG_CACHE_MAX_ENTRIES=500

# -----------------------------
# Vector/indexer
# -----------------------------
VECTOR_STORE_PATH=.vector_store.json
VECTOR_STORE_PREFER_LOCAL=false
INDEXER_STATE_PATH=.indexer_state.json

# -----------------------------
# Agentes
# -----------------------------
AGENT_TOOLS_DIR=./agent-tools
REMOTE_API_URL=
REMOTE_API_KEY=

# -----------------------------
# Mongo (para docker-compose)
# -----------------------------
MONGO_PASSWORD=changeme
