# Ollama SaaS Gateway - variables de entorno (local dev)
# Generado para desarrollo local -- todos los servicios en localhost
#
# Formato de opciones:  # Opciones: val1 | val2 | val3  (default: valX)

# ---------------------------------------------------------
# Core
# ---------------------------------------------------------
# Puerto donde escucha el API Gateway
# Opciones: cualquier puerto libre (1024-65535)  (default: 8081)
PORT=8081

# Habilitar autenticacion JWT en rutas protegidas
# Opciones: true | false  (default: false)
JWT_ENABLED=false

# Secreto para firmar tokens JWT -- cadena hex de 32+ bytes
# Opciones: cadena hexadecimal de >=64 caracteres  (default: autogenerado si vacio)
JWT_SECRET=de454c617e0c5420918bc01bf61239c50dd52b03a57b8dc33913e33221f18bd3

# Directorio raiz del repositorio para operaciones de archivos
# Opciones: ruta absoluta o relativa  (default: ".")
REPO_ROOT=.

# ---------------------------------------------------------
# Servicios (backends)
# ---------------------------------------------------------
# URL del servidor Ollama
# Opciones: http://localhost:11434 | http://ollama:11434 | http://<host>:<port>  (default: http://ollama:11434)
OLLAMA_URL=http://192.168.1.198:11434


# URL del servidor Qdrant (vector DB)
# Opciones: http://localhost:6333 | http://qdrant:6333 | http://<host>:<port>  (default: http://qdrant:6333)
QDRANT_URL=http://localhost:6333

# URI de conexion a MongoDB
# Opciones: mongodb://localhost:27017 | mongodb://user:pass@host:27017/db  (default: mongodb://localhost:27017)
MONGO_URI=mongodb://localhost:27017

# ---------------------------------------------------------
# Modelos
# ---------------------------------------------------------
# Modelo principal de chat -- debe estar descargado en Ollama
# Opciones: qwen2.5-coder:7b | phi3:latest | llama3:8b | mistral:7b | local-rag | cualquier modelo de `ollama list`  (default: local-rag)
CHAT_MODEL=qwen2.5-coder:7b

# Modelo de embeddings -- debe soportar generacion de vectores
# Opciones: nomic-embed-text | nomic-embed-text:latest | mxbai-embed-large | all-minilm  (default: nomic-embed-text:latest)
EMBEDDING_MODEL=nomic-embed-text:latest

# Tiempo que Ollama mantiene el modelo en memoria tras la ultima peticion
# Opciones: 5m | 10m | 30m | 1h | -1 (nunca descargar) | 0 (descargar inmediatamente)  (default: -1)
OLLAMA_KEEP_ALIVE=5m

# ---------------------------------------------------------
# Logging
# ---------------------------------------------------------
# Nivel de log
# Opciones: debug | info | warn | error  (default: info)
LOG_LEVEL=info

# Formato de salida de logs
# Opciones: json | text  (default: json)
LOG_FORMAT=json

# ---------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------
# Limite global de peticiones por minuto
# Opciones: entero > 0 (ej. 60, 120, 300, 1000)  (default: 60)
RATE_LIMIT_RPM=300

# Limite por usuario de peticiones por minuto
# Opciones: entero > 0 (ej. 30, 60, 300)  (default: 60)
RATE_LIMIT_USER_RPM=3

# ---------------------------------------------------------
# HTTP resiliencia
# ---------------------------------------------------------
# Timeout para peticiones HTTP salientes (segundos)
# Opciones: entero > 0 (ej. 10, 30, 60, 120)  (default: 30)
HTTP_TIMEOUT_SECONDS=30

# Reintentos maximos para peticiones HTTP fallidas
# Opciones: 0 (sin reintentos) | 1 | 2 | 3 | 5  (default: 3)
HTTP_MAX_RETRIES=5

# ---------------------------------------------------------
# Health checks (readiness)
# ---------------------------------------------------------
# Timeout de cada health check en milisegundos
# Opciones: entero > 0 (ej. 1000, 2000, 5000)  (default: 2000)
HEALTH_CHECK_TIMEOUT_MS=3000

# ---------------------------------------------------------
# Caches
# ---------------------------------------------------------
# Backend de cache
# Opciones: memory | redis  (default: memory)
CACHE_BACKEND=memory

# URL de conexion a Redis (solo si CACHE_BACKEND=redis)
# Opciones: redis://localhost:6379/0 | redis://user:pass@host:6379/0  (default: redis://localhost:6379/0)
REDIS_URL=redis://localhost:6379/0

# TTL del cache de embeddings en segundos
# Opciones: entero > 0 (ej. 1800, 3600, 7200, 86400)  (default: 3600)
EMBEDDING_CACHE_TTL_SECONDS=3600

# Maximo de entradas en cache de embeddings
# Opciones: entero > 0 (ej. 500, 1000, 5000)  (default: 1000)
EMBEDDING_CACHE_MAX_ENTRIES=1000

# TTL del cache de resultados RAG en segundos
# Opciones: entero > 0 (ej. 900, 1800, 3600)  (default: 1800)
RAG_CACHE_TTL_SECONDS=1800

# Maximo de entradas en cache RAG
# Opciones: entero > 0 (ej. 200, 500, 1000)  (default: 500)
RAG_CACHE_MAX_ENTRIES=500

# ---------------------------------------------------------
# Vector/indexer
# ---------------------------------------------------------
# Ruta al archivo de almacenamiento vectorial local
# Opciones: ruta relativa o absoluta a archivo .json  (default: .vector_store.json)
VECTOR_STORE_PATH=.vector_store.json

# Preferir almacenamiento vectorial local sobre Qdrant
# Opciones: true | false  (default: false)
VECTOR_STORE_PREFER_LOCAL=false

# Ruta al archivo de estado del indexer
# Opciones: ruta relativa o absoluta a archivo .json  (default: .indexer_state.json)
INDEXER_STATE_PATH=.indexer_state.json

# ---------------------------------------------------------
# Agentes
# ---------------------------------------------------------
# Directorio con herramientas personalizadas de agentes
# Opciones: ruta relativa o absoluta a directorio  (default: ./agent-tools)
AGENT_TOOLS_DIR=./agent-tools

# URL de API remota para fallback de modelos (vacio = sin fallback)
# Opciones: https://api.openai.com/v1 | https://<tu-endpoint> | "" (deshabilitado)  (default: "")
REMOTE_API_URL=

# API Key para la API remota
# Opciones: cadena de texto (ej. sk-...) | "" (deshabilitado)  (default: "")
REMOTE_API_KEY=

# ---------------------------------------------------------
# Mongo (para docker-compose)
# ---------------------------------------------------------
# Password del usuario de MongoDB
# Opciones: cadena segura (minimo 12 caracteres recomendado)  (default: changeme)
MONGO_PASSWORD=changeme

# ---------------------------------------------------------
# Ollama Cloud (web search)
# ---------------------------------------------------------
# API Key de Ollama Cloud para web search (https://ollama.com/api/web_search)
# Opciones: cadena con formato "xxx.yyy" | "" (deshabilitado)  (default: "")
OLLAMA_API_KEY=300cd0153ff24556bfa6fa8cd413aeb7.qPVxjP3TjWkB_GQLPMpAy82u
