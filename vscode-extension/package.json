{
  "name": "copilot-local",
  "displayName": "Copilot Local",
  "description": "Local Copilot extension with HTTP SSE streaming and chat panel",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.60.0"
  },
  "activationEvents": [
    "onCommand:copilot-local.sendSelection",
    "onCommand:copilot-local.openChat",
    "onCommand:copilot-local.debugError",
    "onCommand:copilot-local.translateSelection",
    "onCommand:copilot-local.addTests",
    "onCommand:copilot-local.explainSelection",
    "onCommand:copilot-local.refactorSelection",
    "onCommand:copilot-local.fixErrors",
    "onCommand:copilot-local.reindex",
    "onCommand:copilot-local.showStats",
    "onCommand:copilot-local.joinSession",
    "onCommand:copilot-local.commitMessage",
    "onCommand:copilot-local.quickPrompt",
    "onCommand:copilot-local.searchHistory",
    "onCommand:copilot-local.compareModels",
    "onCommand:copilot-local.openFavorites",
    "onCommand:copilot-local.resetQualityAlerts",
    "onCommand:copilot-local.switchProfile",
    "onCommand:copilot-local.clearSessionState",
    "onCommand:copilot-local.explainTestFailure",
    "onCommand:copilot-local.semanticSearch",
    "onCommand:copilot-local.validateLocalModels"
  ],
  "main": "dist/extension.js",
  "scripts": {
    "compile": "tsc -p .",
    "build": "npm run compile",
    "size:check": "node scripts/check-size.js"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
	"@types/node": "^22.15.17",
	"@types/vscode": "^1.60.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "contributes": {
    "commands": [
      {
        "command": "copilot-local.sendSelection",
        "title": "Copilot Local: Send Selection"
      },
      {
        "command": "copilot-local.openChat",
        "title": "Copilot Local: Open Chat Panel"
      },
      {
        "command": "copilot-local.debugError",
        "title": "Copilot Local: Debug Error"
      },
      {
        "command": "copilot-local.translateSelection",
        "title": "Copilot Local: Translate Selection"
      },
      {
        "command": "copilot-local.addTests",
        "title": "Copilot Local: Add Tests"
      },
      {
        "command": "copilot-local.explainSelection",
        "title": "Copilot Local: Explain Selection"
      },
      {
        "command": "copilot-local.refactorSelection",
        "title": "Copilot Local: Refactor Selection"
      },
      {
        "command": "copilot-local.fixErrors",
        "title": "Copilot Local: Fix Errors In Selection"
      },
      {
        "command": "copilot-local.reindex",
        "title": "Copilot Local: Reindex Repository"
      },
      {
        "command": "copilot-local.showStats",
        "title": "Copilot Local: Show Usage Stats"
      },
      {
        "command": "copilot-local.joinSession",
        "title": "Copilot Local: Join Shared Session"
      },
      {
        "command": "copilot-local.commitMessage",
        "title": "Copilot Local: Suggest Commit Message"
      },
      {
        "command": "copilot-local.quickPrompt",
        "title": "Copilot Local: Quick Prompt"
      },
      {
        "command": "copilot-local.searchHistory",
        "title": "Copilot Local: Search Chat History"
      },
      {
        "command": "copilot-local.compareModels",
        "title": "Copilot Local: Compare Models"
      },
      {
        "command": "copilot-local.openFavorites",
        "title": "Copilot Local: Open Favorites"
      },
      {
        "command": "copilot-local.resetQualityAlerts",
        "title": "Copilot Local: Reset Quality Alerts"
      },
      {
        "command": "copilot-local.switchProfile",
        "title": "Copilot Local: Switch Workspace Profile"
      },
      {
        "command": "copilot-local.clearSessionState",
        "title": "Copilot Local: Clear Session State"
      },
      {
        "command": "copilot-local.explainTestFailure",
        "title": "Copilot Local: Explain Test Failure"
      },
      {
        "command": "copilot-local.semanticSearch",
        "title": "Copilot Local: Semantic Search"
      },
      {
        "command": "copilot-local.validateLocalModels",
        "title": "Copilot Local: Validate Local Models"
      }
    ],
    "keybindings": [
      {
        "command": "copilot-local.sendSelection",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorTextFocus"
      },
      {
        "command": "copilot-local.openChat",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      },
      {
        "command": "copilot-local.explainSelection",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorTextFocus"
      },
      {
        "command": "copilot-local.refactorSelection",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorTextFocus"
      },
      {
        "command": "copilot-local.addTests",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "editorTextFocus"
      },
      {
        "command": "copilot-local.fixErrors",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "editorTextFocus"
      }
    ],
    "submenus": [
      {
        "id": "copilotLocal.submenu",
        "label": "Copilot Local"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "copilotLocal.submenu",
          "group": "navigation"
        }
      ],
      "copilotLocal.submenu": [
        {
          "command": "copilot-local.explainSelection",
          "group": "1_main"
        },
        {
          "command": "copilot-local.refactorSelection",
          "group": "1_main"
        },
        {
          "command": "copilot-local.addTests",
          "group": "1_main"
        },
        {
          "command": "copilot-local.fixErrors",
          "group": "1_main"
        },
        {
          "command": "copilot-local.quickPrompt",
          "group": "1_main"
        },
        {
          "command": "copilot-local.compareModels",
          "group": "1_main"
        },
        {
          "command": "copilot-local.openFavorites",
          "group": "1_main"
        },
        {
          "command": "copilot-local.switchProfile",
          "group": "1_main"
        },
        {
          "command": "copilot-local.semanticSearch",
          "group": "1_main"
        },
        {
          "command": "copilot-local.validateLocalModels",
          "group": "2_tools"
        },
        {
          "command": "copilot-local.clearSessionState",
          "group": "2_tools"
        },
        {
          "command": "copilot-local.explainTestFailure",
          "group": "2_tools"
        },
        {
          "command": "copilot-local.resetQualityAlerts",
          "group": "2_tools"
        }
      ]
    },
    "configuration": {
      "title": "Copilot Local",
      "properties": {
        "copilotLocal.apiUrl": {
          "type": "string",
          "default": "http://localhost:8081",
          "description": "Base URL of the local gateway (e.g. http://localhost:8081)"
        },
        "copilotLocal.model": {
          "type": "string",
          "default": "local-rag",
          "description": "Default model to request"
        },
        "copilotLocal.chatModel": {
          "type": "string",
          "default": "",
          "description": "Dedicated model for chat requests. Empty uses copilotLocal.model"
        },
        "copilotLocal.fimModel": {
          "type": "string",
          "default": "",
          "description": "Dedicated model for inline completions/FIM. Empty uses copilotLocal.model"
        },
        "copilotLocal.embeddingModel": {
          "type": "string",
          "default": "nomic-embed-text",
          "description": "Preferred embedding model name used by the gateway"
        },
        "copilotLocal.workspaceModel": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Workspace-scoped model override for the active profile"
        },
        "copilotLocal.workspaceLang": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Workspace-scoped response language override for the active profile"
        },
        "copilotLocal.workspaceTemperature": {
          "type": "number",
          "default": 0.3,
          "scope": "resource",
          "description": "Workspace-scoped temperature override for the active profile"
        },
        "copilotLocal.workspaceActiveProfile": {
          "type": "string",
          "default": "balanced",
          "scope": "resource",
          "description": "Active workspace profile id"
        },
        "copilotLocal.workspaceProfiles": {
          "type": "object",
          "scope": "resource",
          "default": {
            "fast": {
              "model": "local-rag",
              "lang": "es",
              "temperature": 0.1
            },
            "balanced": {
              "model": "local-rag",
              "lang": "es",
              "temperature": 0.3
            },
            "deep-analysis": {
              "model": "local-rag",
              "lang": "es",
              "temperature": 0.6
            }
          },
          "description": "Workspace-scoped profile presets. Each profile supports model/lang/temperature"
        },
        "copilotLocal.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to copilot-cli binary (fallback when HTTP is unavailable)"
        },
        "copilotLocal.jwtToken": {
          "type": "string",
          "default": "",
          "description": "JWT token for authenticated endpoints (optional)"
        },
        "copilotLocal.inlineCompletions": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline ghost text completions"
        },
        "copilotLocal.chatFontSize": {
          "type": "number",
          "default": 13,
          "description": "Font size used in chat panel"
        },
        "copilotLocal.voiceInputEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable voice dictation in the chat panel when Web Speech API is available"
        },
        "copilotLocal.quickPromptTemplates": {
          "type": "object",
          "default": {},
          "description": "Custom quick prompt templates as JSON object, e.g. { \"review\": \"Review this code:\\n{{selection}}\" }"
        },
        "copilotLocal.qualityAlertsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable local quality alerts based on latency and consecutive errors"
        },
        "copilotLocal.qualityLatencyThresholdMs": {
          "type": "number",
          "default": 8000,
          "description": "Latency threshold in ms for quality warnings"
        },
        "copilotLocal.qualityConsecutiveErrorsThreshold": {
          "type": "number",
          "default": 3,
          "description": "Consecutive error threshold for quality warnings"
        }
      }
    }
  }
}
